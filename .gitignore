# ============================================================
# 环境变量（含密码等敏感信息）
# ============================================================
.env

# ============================================================
# 数据文件（体积大、可通过脚本重新生成）
# ============================================================
# 数据库文件（app/server/data/）
app/server/data/*.db
app/server/data/*.db-shm
app/server/data/*.db-wal

data/pets/*.json
data/pets/*.csv
data/skills/*.json
data/skills/*.csv
data/elements/*.json
data/elements/*.csv
data/eggs/*.json
data/natures/*.json

# 图片资源（通过爬虫下载生成）
data/public/

# 校验报告（每次运行自动生成）
data/**/*_report.md

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.egg
venv/
.venv/
env/

# ============================================================
# IDE / 编辑器
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================
# 系统文件
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# 日志 / 临时文件
# ============================================================
*.log
data/**/*_log.txt
data/**/_update_filter.json

# ============================================================
# 部署文档（仅本地使用）
# ============================================================
DEPLOY.md
deploy.sh
setup-nginx.sh

# 根路径静态文件（验证文件、证书等，仅服务器使用）
app/server/root-static/*
!app/server/root-static/.gitkeep

# ============================================================
# CodeBuddy
# ============================================================
.codebuddy/
data/uploads/
